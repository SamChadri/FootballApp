<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Football.MauiApp.ViewModels"
             x:Class="Football.MauiApp.Views.AddPlayerPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#000000"
             Title="Add Player">

    <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Padding="24,48,24,12">
            <Border WidthRequest="40" HeightRequest="40"
                    BackgroundColor="#1A1A1A"
                    Margin="0,0,16,0"
                    VerticalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                <Label Text="‹" TextColor="White" FontSize="22" FontAttributes="Bold"
                       HorizontalOptions="Center" VerticalOptions="Center" />
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Border.GestureRecognizers>
            </Border>
            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                <Label Text="NEW PLAYER"
                       TextColor="White"
                       FontSize="22"
                       FontAttributes="Bold"
                       CharacterSpacing="2" />
                <Label Text="ROSTER"
                       TextColor="#FF6B00"
                       FontSize="10"
                       CharacterSpacing="2"
                       FontAttributes="Bold" />
            </VerticalStackLayout>
        </Grid>

        <ScrollView Grid.Row="1">
            <Grid Padding="24,8,24,32"
                  ColumnDefinitions="*,*"
                  ColumnSpacing="20"
                  MinimumHeightRequest="420">

                <Border Grid.Column="0"
                        BackgroundColor="#111111"
                        StrokeThickness="1"
                        Stroke="#2A2A2A"
                        Padding="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                    <Grid>
                        <Image Source="players_bg.jpg"
                               Aspect="AspectCrop"
                               Opacity="0.95" />
                        <Border BackgroundColor="#88000000"
                                Padding="20">
                            <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                            <VerticalStackLayout VerticalOptions="End" Spacing="8">
                                <Label Text="PLAYER"
                                       TextColor="White"
                                       FontSize="28"
                                       FontAttributes="Bold" />
                                <Label Text="Jersey number, position group, and class year."
                                       TextColor="#CCCCCC"
                                       FontSize="13"
                                       LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </Border>

                <VerticalStackLayout Grid.Column="1"
                                     Spacing="14"
                                     VerticalOptions="Center">

                    <Label Text="Details"
                           TextColor="White"
                           FontSize="18"
                           FontAttributes="Bold" />

                    <Label Text="JERSEY #" TextColor="#888888" FontSize="10" CharacterSpacing="1" />
                    <Border BackgroundColor="#1A1A1A" StrokeThickness="1" Stroke="#2A2A2A" Padding="12,8">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                        <Entry Placeholder="64"
                               PlaceholderColor="#666666"
                               TextColor="White"
                               Keyboard="Numeric"
                               Text="{Binding NumberText}" />
                    </Border>

                    <Label Text="NAME" TextColor="#888888" FontSize="10" CharacterSpacing="1" />
                    <Border BackgroundColor="#1A1A1A" StrokeThickness="1" Stroke="#2A2A2A" Padding="12,8">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                        <Entry Placeholder="Full name"
                               PlaceholderColor="#666666"
                               TextColor="White"
                               Text="{Binding Name}" />
                    </Border>

                    <Label Text="POSITION" TextColor="#888888" FontSize="10" CharacterSpacing="1" />
                    <Border BackgroundColor="#1A1A1A" StrokeThickness="1" Stroke="#2A2A2A" Padding="12,8">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                        <Entry Placeholder="e.g. Defensive Line"
                               PlaceholderColor="#666666"
                               TextColor="White"
                               Text="{Binding Position}" />
                    </Border>

                    <Label Text="YEAR" TextColor="#888888" FontSize="10" CharacterSpacing="1" />
                    <Border BackgroundColor="#1A1A1A" StrokeThickness="1" Stroke="#2A2A2A" Padding="12,8">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                        <Entry Placeholder="FR / SO / JR / SR"
                               PlaceholderColor="#666666"
                               TextColor="White"
                               Text="{Binding Year}" />
                    </Border>

                    <Label Text="TEAM ID" TextColor="#888888" FontSize="10" CharacterSpacing="1" />
                    <Border BackgroundColor="#1A1A1A" StrokeThickness="1" Stroke="#2A2A2A" Padding="12,8">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                        <Entry Placeholder="1"
                               PlaceholderColor="#666666"
                               TextColor="White"
                               Keyboard="Numeric"
                               Text="{Binding TeamIdText}" />
                    </Border>

                    <Button Text="SAVE PLAYER"
                            BackgroundColor="#FF6B00"
                            TextColor="Black"
                            FontAttributes="Bold"
                            CornerRadius="12"
                            Margin="0,12,0,0"
                            Clicked="OnSaveClicked" />
                </VerticalStackLayout>
            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>
