<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Football.MauiApp.ViewModels"
             xmlns:core="clr-namespace:Football.Core;assembly=Football.Core"
             x:Class="Football.MauiApp.Views.PositionPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#000000"
             Title="Position">

    <Grid RowDefinitions="Auto,Auto,*" Padding="24,60,24,24">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,32">
            <Border Grid.Column="0"
                    WidthRequest="40" HeightRequest="40"
                    BackgroundColor="#1A1A1A"
                    Margin="0,0,16,0"
                    VerticalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                <Label Text="‹" TextColor="White" FontSize="22" FontAttributes="Bold"
                       HorizontalOptions="Center" VerticalOptions="Center" />
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Border.GestureRecognizers>
            </Border>
            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                <Label Text="{Binding PageTitle}"
                       TextColor="White" FontSize="22" FontAttributes="Bold" />
                <Label Text="SELECT A POSITION"
                       TextColor="#FF6B00" FontSize="12" CharacterSpacing="3" FontAttributes="Bold" />
            </VerticalStackLayout>
        </Grid>

        <!-- Divider -->
        <BoxView Grid.Row="1" HeightRequest="1" Color="#1F1F1F" Margin="0,0,0,32" />

        <!-- Position Grid -->
        <ScrollView Grid.Row="2">
            <FlexLayout BindableLayout.ItemsSource="{Binding Positions}"
                        Wrap="Wrap"
                        JustifyContent="Start"
                        AlignItems="Start">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="core:PositionGroup">
                        <Border BackgroundColor="#111111"
                                StrokeThickness="1"
                                Stroke="#2A2A2A"
                                WidthRequest="160"
                                HeightRequest="100"
                                Margin="0,0,12,12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>

                            <Grid RowDefinitions="*,Auto" Padding="16,12">
                                <Label Grid.Row="0"
                                       Text="{Binding Name}"
                                       TextColor="White"
                                       FontSize="24"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center" />
                                <Label Grid.Row="1"
                                       Text="View Stats ›"
                                       TextColor="#FF6B00"
                                       FontSize="12" />
                            </Grid>

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:PositionViewModel}}, Path=SelectPositionCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>
        </ScrollView>
    </Grid>
</ContentPage>
