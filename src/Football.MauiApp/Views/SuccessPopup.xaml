<?xml version="1.0" encoding="utf-8" ?>

<toolkit:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:Class="Football.MauiApp.Views.SuccessPopup"
    CanBeDismissedByTappingOutsideOfPopup="False">

    <Border
        BackgroundColor="#111111"
        Stroke="#2C2C2C"
        StrokeThickness="1"
        Padding="28"
        WidthRequest="320">

        <Border.StrokeShape>
            <RoundRectangle CornerRadius="18"/>
        </Border.StrokeShape>

        <VerticalStackLayout
            Spacing="18"
            HorizontalOptions="Center">

            <!-- Success Icon -->
            <Border
                WidthRequest="72"
                HeightRequest="72"
                BackgroundColor="#FF6B00"
                StrokeThickness="0">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="36"/>
                </Border.StrokeShape>

                <Label
                    Text="✓"
                    FontSize="38"
                    FontAttributes="Bold"
                    TextColor="White"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"/>
            </Border>

            <Label
                x:Name="TitleLabel"
                Text="Success"
                FontSize="24"
                FontAttributes="Bold"
                TextColor="White"
                HorizontalTextAlignment="Center"/>

            <Label
                x:Name="MessageLabel"
                Text="Item saved successfully."
                FontSize="15"
                TextColor="#CCCCCC"
                HorizontalTextAlignment="Center"/>

            <HorizontalStackLayout
                Spacing="12"
                HorizontalOptions="Center">

                <Button
                    Text="Done"
                    Clicked="DoneClicked"
                    BackgroundColor="#FF6B00"
                    TextColor="White"
                    WidthRequest="120"/>

                <Button
                    Text="Add Another"
                    Clicked="AddAnotherClicked"
                    BackgroundColor="Transparent"
                    BorderColor="#555555"
                    BorderWidth="1"
                    TextColor="White"
                    WidthRequest="120"/>
            </HorizontalStackLayout>

        </VerticalStackLayout>

    </Border>

</toolkit:Popup>