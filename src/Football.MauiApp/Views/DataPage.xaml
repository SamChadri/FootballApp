<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Football.MauiApp.ViewModels"
             xmlns:core="clr-namespace:Football.Core;assembly=Football.Core"
             x:Class="Football.MauiApp.Views.DataPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#000000"
             Title="Data">

    <ContentPage.BindingContext>
        <vm:DataViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,Auto,*" Padding="24,60,24,24">

        <!-- Header with back button -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,20">
            <Border Grid.Column="0"
                    WidthRequest="40" HeightRequest="40"
                    BackgroundColor="#1A1A1A"
                    Margin="0,0,16,0"
                    VerticalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                <Label Text="‹" TextColor="White" FontSize="22" FontAttributes="Bold"
                       HorizontalOptions="Center" VerticalOptions="Center" />
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Border.GestureRecognizers>
            </Border>
            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                <Label Text="DATA"
                       TextColor="White"
                       FontSize="32"
                       FontAttributes="Bold"
                       CharacterSpacing="4" />
                <Label Text="SELECT A SEASON"
                       TextColor="#FF6B00"
                       FontSize="12"
                       CharacterSpacing="3"
                       FontAttributes="Bold" />
            </VerticalStackLayout>
        </Grid>

        <!-- Divider -->
        <BoxView Grid.Row="1" HeightRequest="1" Color="#1F1F1F" Margin="0,0,0,20" />

        <!-- Scrollable body -->
        <ScrollView Grid.Row="2">
            <VerticalStackLayout Spacing="24">

                <!-- ── Season Comparison Chart ── -->
                <Border BackgroundColor="#111111"
                        StrokeThickness="1"
                        Stroke="#2A2A2A"
                        Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="14">
                        <Label Text="TACKLES BY SEASON"
                               TextColor="#888888"
                               FontSize="11"
                               CharacterSpacing="2"
                               FontAttributes="Bold" />

                        <!-- Horizontal bar per season -->
                        <VerticalStackLayout Spacing="10"
                                             BindableLayout.ItemsSource="{Binding SeasonChart}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="vm:SeasonSummaryBar">
                                    <Grid ColumnDefinitions="50,*,60" ColumnSpacing="10" HeightRequest="32">
                                        <!-- Year label -->
                                        <Label Grid.Column="0"
                                               Text="{Binding Year}"
                                               TextColor="#888888"
                                               FontSize="13"
                                               VerticalOptions="Center"
                                               HorizontalOptions="End" />
                                        <!-- Bar track -->
                                        <Grid Grid.Column="1" VerticalOptions="Center">
                                            <BoxView BackgroundColor="#1E1E1E"
                                                     HeightRequest="12"
                                                     CornerRadius="6"
                                                     HorizontalOptions="Fill" />
                                            <!-- Filled portion -->
                                            <BoxView BackgroundColor="#FF6B00"
                                                     HeightRequest="12"
                                                     WidthRequest="{Binding BarWidth}"
                                                     CornerRadius="6"
                                                     HorizontalOptions="Start" />
                                        </Grid>
                                        <!-- Value label -->
                                        <Label Grid.Column="2"
                                               Text="{Binding TackleLabel}"
                                               TextColor="#FF6B00"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- ── Season Cards ── -->
                <Label Text="SELECT A SEASON"
                       TextColor="#888888"
                       FontSize="11"
                       CharacterSpacing="2"
                       FontAttributes="Bold"
                       Margin="4,0" />

                <VerticalStackLayout Spacing="12"
                                     BindableLayout.ItemsSource="{Binding Seasons}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="core:Season">
                            <Border BackgroundColor="#111111"
                                    StrokeThickness="1"
                                    Stroke="#2A2A2A"
                                    Padding="24,18">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="16" />
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="*,Auto">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                                        <Label Text="{Binding Year}"
                                               TextColor="White"
                                               FontSize="26"
                                               FontAttributes="Bold" />
                                        <Label Text="Season"
                                               TextColor="#666666"
                                               FontSize="12" />
                                    </VerticalStackLayout>
                                    <Border Grid.Column="1"
                                            WidthRequest="40" HeightRequest="40"
                                            BackgroundColor="#FF6B00"
                                            VerticalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="20" />
                                        </Border.StrokeShape>
                                        <Label Text="›" TextColor="White" FontSize="22"
                                               FontAttributes="Bold"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Border>
                                </Grid>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DataViewModel}}, Path=SelectSeasonCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
