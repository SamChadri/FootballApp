<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Football.MauiApp.ViewModels"
             x:Class="Football.MauiApp.Views.HomePage"
             Shell.NavBarIsVisible="False"
             Title="Home">

    <ContentPage.BindingContext>
        <vm:HomeViewModel />
    </ContentPage.BindingContext>

    <Grid>
        <!-- Layer 1: Dynamic Backgrounds with Cross-Fade -->
        <Image x:Name="BgImageB" 
               Aspect="AspectFill" 
               Opacity="0" />
        <Image x:Name="BgImageA" 
               Aspect="AspectFill" 
               Source="home_bg.jpg" />

        <!-- Layer 2: Logos -->
        <Grid ColumnDefinitions="*, *" VerticalOptions="Start" Padding="20, 60">
            <Image Source="nike_logo_transparent.png" 
                   WidthRequest="60" 
                   HorizontalOptions="Start" />
            <Image Grid.Column="1" 
                   Source="nike_nocta_logo_transparent.png" 
                   WidthRequest="60" 
                   HorizontalOptions="End" />
        </Grid>

        <!-- Layer 3: Main Carousel Menu -->
        <CarouselView x:Name="MenuCarousel"
                      ItemsSource="{Binding MenuItems}"
                      Position="{Binding CurrentPosition}"
                      Loop="False"
                      VerticalOptions="End"
                      HeightRequest="300"
                      Margin="0,0,0,50"
                      PeekAreaInsets="100">
            <CarouselView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal" SnapPointsType="MandatorySingle" SnapPointsAlignment="Center" />
            </CarouselView.ItemsLayout>
            <CarouselView.ItemTemplate>
                <DataTemplate x:DataType="vm:HomeItem">
                    <Grid Padding="10">
                        <!-- 3D Card with Trim and Glow -->
                        <Border x:Name="CardBorder"
                                Stroke="White"
                                StrokeThickness="1"
                                BackgroundColor="#33000000"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                WidthRequest="180"
                                HeightRequest="120">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#FF6F00" Offset="0,0" Radius="20" Opacity="0.8" />
                            </Border.Shadow>
                            
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroupList>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal">
                                            <VisualState.Setters>
                                                <Setter Property="Scale" Value="0.7" />
                                                <Setter Property="Opacity" Value="0.5" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Current">
                                            <VisualState.Setters>
                                                <Setter Property="Scale" Value="1.2" />
                                                <Setter Property="Opacity" Value="1.0" />
                                                <Setter Property="ZIndex" Value="1" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateGroupList>
                            </VisualStateManager.VisualStateGroups>

                            <Grid>
                                <Label Text="{Binding Title}" 
                                       TextColor="White" 
                                       FontSize="20" 
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center" 
                                       VerticalOptions="Center" />
                                
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=EnterSectionCommand}" 
                                                          CommandParameter="{Binding .}" />
                                </Grid.GestureRecognizers>
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CarouselView.ItemTemplate>
        </CarouselView>
    </Grid>
</ContentPage>
