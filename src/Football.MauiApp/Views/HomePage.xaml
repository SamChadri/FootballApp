<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Football.MauiApp.ViewModels"
             x:Class="Football.MauiApp.Views.HomePage"
             Shell.NavBarIsVisible="False"
             Title="Home">

    <ContentPage.BindingContext>
        <vm:HomeViewModel />
    </ContentPage.BindingContext>

    <Grid>
        <!-- Layer 1: Dynamic Backgrounds with Cross-Fade -->
        <Image x:Name="BgImageB" 
               Aspect="AspectFill" 
               Opacity="0" />
        <Image x:Name="BgImageA" 
               Aspect="AspectFill" 
               Source="home_bg.png" />

        <!-- Layer 2: Logos -->

        <!--
        <Grid ColumnDefinitions="*, *" VerticalOptions="Start" Padding="20, 60">
            <Image Source="nike_logo_transparent.png" 
                   WidthRequest="60" 
                   HorizontalOptions="Start" />
            <Image Grid.Column="1" 
                   Source="nike_nocta_logo_transparent.png" 
                   WidthRequest="60" 
                   HorizontalOptions="End" />
        </Grid>
        -->
        <!-- Layer 3: Main Carousel Menu -->
        <Grid HorizontalOptions="FillAndExpand" 
              VerticalOptions="FillAndExpand"
              InputTransparent="True">

            <VerticalStackLayout HorizontalOptions="Center" 
                                  VerticalOptions="Center"
                                  Margin="20,0">
                <Label Text="HAIL TO THE ORANGE"
                       TextColor="White"
                       FontSize="80"
                       FontAttributes="Bold"
                       Opacity="0.3"
                       HorizontalOptions="FillAndExpand"
                       HorizontalTextAlignment="Center"
                       LineBreakMode="NoWrap" />
                <Label Text="GAMES"
                       TextColor="Orange"
                       FontSize="28"
                       FontAttributes="Bold"
                       Opacity="0.4"
                       Margin="0,-10,0,0"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>
        <CarouselView x:Name="MenuCarousel"
                      ItemsSource="{Binding MenuItems}"
                      Position="{Binding CurrentPosition}"
                      Loop="False"
                      VerticalOptions="End"
                      HeightRequest="200"
                      PeekAreaInsets="100"
                      Margin="0,0,0,30"
                      HorizontalScrollBarVisibility="Never"
                      VerticalScrollBarVisibility="Never">
            <CarouselView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal" SnapPointsType="MandatorySingle" SnapPointsAlignment="Center" />
            </CarouselView.ItemsLayout>
            <CarouselView.ItemTemplate>
                <DataTemplate x:DataType="vm:HomeItem">
                    <Grid Padding="20" HeightRequest="200">

                        <!-- VSM must be on the root DataTemplate element so CarouselView can apply Current/Normal states -->
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroupList>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal">
                                        <VisualState.Setters>
                                            <Setter Property="Scale" Value="0.7" />
                                            <Setter Property="Opacity" Value="0.6" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Current">
                                        <VisualState.Setters>
                                            <Setter Property="Scale" Value="1.3" />
                                            <Setter Property="Opacity" Value="1.0" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateGroupList>
                        </VisualStateManager.VisualStateGroups>

                        <!-- 3D Circle Card with Glow -->
                        <Border Stroke="White"
                                StrokeThickness="1"
                                BackgroundColor="Black"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                WidthRequest="80"
                                HeightRequest="80">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="40" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Orange" Offset="0,0" Radius="30" Opacity="0.9" />
                            </Border.Shadow>

                            <Grid>
                                <Label Text="{Binding Title}"
                                       TextColor="White"
                                       FontSize="10"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />

                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=EnterSectionCommand}"
                                                          CommandParameter="{Binding .}" />
                                </Grid.GestureRecognizers>
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CarouselView.ItemTemplate>
        </CarouselView>
    </Grid>
</ContentPage>
