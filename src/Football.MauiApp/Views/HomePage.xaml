<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Football.MauiApp.ViewModels"
             x:Class="Football.MauiApp.Views.HomePage"
             Shell.NavBarIsVisible="False"
             Title="Home">

    <ContentPage.BindingContext>
        <vm:HomeViewModel />
    </ContentPage.BindingContext>

    <Grid>
        <!-- Layer 1: Dynamic Backgrounds with Cross-Fade -->
        <Image x:Name="BgImageB" 
               Aspect="AspectFill" 
               Opacity="0" />
        <Image x:Name="BgImageA" 
               Aspect="AspectFill" 
               Source="home_bg.png" />

        <!-- Layer 2: Logos -->

        <!--
        <Grid ColumnDefinitions="*, *" VerticalOptions="Start" Padding="20, 60">
            <Image Source="nike_logo_transparent.png" 
                   WidthRequest="60" 
                   HorizontalOptions="Start" />
            <Image Grid.Column="1" 
                   Source="nike_nocta_logo_transparent.png" 
                   WidthRequest="60" 
                   HorizontalOptions="End" />
        </Grid>
        -->
        <!-- Layer 3: Main Carousel Menu -->
        <Grid HorizontalOptions="FillAndExpand" 
              VerticalOptions="FillAndExpand"
              InputTransparent="True">

            <VerticalStackLayout HorizontalOptions="Center" 
                                  VerticalOptions="Center"
                                  Margin="20,0">
                <Label Text="HAIL TO THE ORANGE"
                       TextColor="White"
                       FontSize="80"
                       FontAttributes="Bold"
                       Opacity="0.3"
                       HorizontalOptions="FillAndExpand"
                       HorizontalTextAlignment="Center"
                       LineBreakMode="NoWrap" />
                <Label Text="GAMES"
                       TextColor="Orange"
                       FontSize="28"
                       FontAttributes="Bold"
                       Opacity="0.4"
                       Margin="0,-10,0,0"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>
        <!-- Layer 3: Circle Navigation Row -->
        <HorizontalStackLayout HorizontalOptions="Center"
                               VerticalOptions="End"
                               Spacing="12"
                               Margin="0,0,0,40"
                               BindableLayout.ItemsSource="{Binding MenuItems}">
            <BindableLayout.ItemTemplate>
                <DataTemplate x:DataType="vm:HomeItem">
                    <Border WidthRequest="60"
                            HeightRequest="60"
                            BackgroundColor="Black"
                            Stroke="White"
                            StrokeThickness="1"
                            Scale="0.85"
                            Opacity="0.6">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="30" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Orange" Offset="0,0" Radius="8" Opacity="0.4" />
                        </Border.Shadow>
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="Scale" Value="1.25" />
                                <Setter Property="Opacity" Value="1.0" />
                                <Setter Property="Stroke" Value="Orange" />
                                <Setter Property="StrokeThickness" Value="2" />
                            </DataTrigger>
                        </Border.Triggers>

                        <Grid>
                            <Label Text="{Binding Title}"
                                   TextColor="White"
                                   FontSize="9"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=SelectItemCommand}"
                                                      CommandParameter="{Binding .}" />
                            </Grid.GestureRecognizers>
                        </Grid>
                    </Border>
                </DataTemplate>
            </BindableLayout.ItemTemplate>
        </HorizontalStackLayout>
    </Grid>
</ContentPage>
