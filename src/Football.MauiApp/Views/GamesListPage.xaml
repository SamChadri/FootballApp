<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Football.MauiApp.ViewModels"
             x:Class="Football.MauiApp.Views.GamesListPage"
             Title="Games">
    
    <Grid RowDefinitions="*, Auto">
        <CollectionView ItemsSource="{Binding Games}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <VerticalStackLayout Padding="10">
                        <Label Text="{Binding Opponent}" FontAttributes="Bold" FontSize="18"/>
                        <HorizontalStackLayout Spacing="5">
                            <Label Text="{Binding Date, StringFormat='{0:MM/dd/yyyy}'}" />
                            <Label Text="-" />
                            <Label Text="{Binding Points}" />
                            <Label Text="to" />
                            <Label Text="{Binding OpponentPoints}" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="1" 
                Text="Add Game" 
                Clicked="OnAddGameClicked" 
                Margin="10" />
    </Grid>
</ContentPage>
